# =====================================================
# C3 NICARAGUA - Environment Variables
# =====================================================
# Copia este archivo como `.env` y completa los valores.

# ---- EmailJS / Resend (Notificaciones por email) ----
# EmailJS entrega el correo a través de SMTP/Resend.
# Crea una cuenta gratuita en https://www.emailjs.com/
# y configura un servicio conectado a Resend (o cualquier SMTP).
#
# 1. Service ID: en EmailJS > Email Services
# 2. Template ID: en EmailJS > Email Templates (configura "To Email" como {{to_email}})
# 3. Public Key: en EmailJS > Account > API Keys

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
